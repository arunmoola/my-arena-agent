# Copy to .env and fill in. .env is gitignored — never commit real values.

# Google AI Studio key for Gemini (https://aistudio.google.com)
export GEMINI_API_KEY=""

# Traceloop/OpenLLMetry key for tracing (optional)
export TRACELOOP_API_KEY=""

# Firebase JWT from the Arena web app: sign in, DevTools → Application →
# Storage, copy the ID token. Expires in ~1 hour, so refresh before each run.
export ARENA_ID_TOKEN=""
